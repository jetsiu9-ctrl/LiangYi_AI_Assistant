{
  "manifestVersion": 5,
  "id": "com.t8mars.zhenzhen.uxp",
  "name": "凉意AI助手",
  "version": "0.2.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0",
    "data": {
      "apiVersion": 2
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "zhenzhenPanel",
      "label": {
        "default": "凉意AI助手"
      },
      "minimumSize": {
        "width": 400,
        "height": 800
      },
      "preferredDockedSize": {
        "width": 400,
        "height": 800
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 800
      },
      "maximumSize": {
        "width": 402,
        "height": 802
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "plugin"
  },
  "featureFlags": {
    "enableSWCSupport": true
  }
}
